# ── Required ──────────────────────────────────────────────────────────────────
DOMAIN=im.example.com
POSTGRES_PASSWORD=change_me_random_string
JWT_SIGNING_KEY=change_me_64_hex_chars

# ── Optional ─────────────────────────────────────────────────────────────────
# DEFAULT_ADMIN_PASSWORD=          # auto-generated if not set, shown in logs on first run
# WEBAUTHN_RP_ID=example.com       # defaults to DOMAIN; set to parent domain to share passkeys across subdomains

# GitHub OAuth (enables "Sign in with GitHub" on the login page)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Generate secrets with:
#   openssl rand -hex 32
